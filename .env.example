# Network
SUI_NETWORK=testnet
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443

# Signing uses the Sui CLI keystore directly, so this can stay blank.
SUI_SECRET_KEY=

# From your `sui client publish` of move/ (v3 with the OTW + init).
PACKAGE_ID=
# The Publisher object the init transfers to you; needed for the Kiosk scripts.
PUBLISHER_ID=

# Walrus storage duration (epochs).
WALRUS_EPOCHS=5

# Optional: reserve-auditor agent. Defaults shown.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:30b
# ROYALTY_PCT=1
